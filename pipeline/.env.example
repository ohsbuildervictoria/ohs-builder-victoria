# Copy to pipeline/.env and fill in. Never commit .env.

# ── Arcads (AI presenter + voiceover) ────────────────────────────────────────
# API access requires the Arcads Pro/custom plan. Get from app.arcads.ai/settings/api.
ARCADS_BASIC_AUTH='Basic your_base64_encoded_credentials_here'
# ARCADS_API_KEY=your_key_here
ARCADS_BASE_URL=https://external-api.arcads.ai
# Optional: pin a specific actor/voice (else the pipeline picks a default).
# ARCADS_ACTOR_ID=
# ARCADS_VOICE_ID=

# ── App under test (Puppeteer screen recording) ──────────────────────────────
# The Nexxt Site Manager app must be running and reachable here first
# (e.g. `npm run preview` in the repo root → http://localhost:4173).
APP_BASE_URL=http://localhost:4173

# ── Supabase (TikTok token store — shared with api/_lib) ─────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── TikTok (post the finished video) ─────────────────────────────────────────
# open_id of the connected @nexxtsitemanager account (row in tiktok_accounts).
TIKTOK_OPEN_ID=
# Needed by api/_lib/tiktok.js to refresh the access token.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
