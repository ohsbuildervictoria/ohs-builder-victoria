# Copy this file to .env and fill in your credentials (never commit .env).
# Values with special characters ({, [, *, etc.) MUST be single-quoted.

# ── Option A (recommended): Pre-encoded Basic auth header ────────────────────
# Find this in your Arcads dashboard (Settings > API). It looks like:
#   Basic ODQxMTg4NDExZDY1NDQ0MmJk...
# This is the most reliable auth method — avoids encoding issues.
ARCADS_BASIC_AUTH='Basic your_base64_encoded_credentials_here'

# ── Option B: API key only ───────────────────────────────────────────────────
# Used as HTTP Basic username with empty password. Some accounts may get 403
# with this method — if so, switch to Option A above.
# ARCADS_API_KEY=your_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# ARCADS_CLIENT_ID=your_client_id_here
# ARCADS_BASE_URL=https://external-api.arcads.ai

# ── Meta Ads (meta-ad-builder shared skill — OPTIONAL) ───────────────────────
# Powers shared/skills/meta-ad-builder/ — publishing creatives as Meta ads.
# Uncomment + fill these in ONLY if you'll publish via the Meta Marketing API.
# Every ad created by the skill is PAUSED — you launch manually in Ads Manager.
# Token needs the ads_management scope.
# META_ACCESS_TOKEN=your_long_lived_token_here
# META_AD_ACCOUNT_ID=act_1234567890
# META_PAGE_ID=
# META_IG_USER_ID=
# META_PIXEL_ID=
# META_API_VERSION=v23.0
